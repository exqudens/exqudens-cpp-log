{
    "formatters": {
        "formatter": {
            "format": "${timestamp} ${level} ${logger} [${thread}] ${function}(${file}:${line}): ${message}",
            "parameters": {
                "timestamp": {"format": "%Y-%m-%d %H:%M:%S", "seconds": 8, "size": 5, "reverse": true},
                "level": {"name": true, "size": 5, "reverse": true},
                "thread": {"size": 5, "reverse": true},
                "logger": {"size": 5, "reverse": true},
                "function": {"size": 5, "reverse": true},
                "file": {"base": "src/main/cpp", "name": true, "size": 5, "reverse": true},
                "line": {"size": 5, "reverse": true},
                "message": {"size": 5, "reverse": true}
            }
        }
    },
    "handlers": {
        "console-handler": {
            "type": "console",
            "stream": "stdout",
            "formatter": "formatter"
        },
        "file-handler": {
            "type": "file",
            "file": "log.txt",
            "size": 1024,
            "formatter": "formatter"
        }
    },
    "loggers": {
        "root": {
            "level": 1,
            "handlers": [
                "console-handler",
                "file-handler"
            ]
        }
    }
}
