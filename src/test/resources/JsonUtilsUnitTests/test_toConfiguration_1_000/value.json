{
    "handlers": {
        "console": {
            "type": "console",
            "level": 1,
            "stream": "stdout",
            "formatter": "formatter"
        },
        "file": {
            "type": "file",
            "level": 1,
            "file": "log.txt",
            "size": 1024,
            "formatter": "formatter"
        }
    },
    "loggers": {
        "root": {
            "level": 1,
            "handlers": [
                "console",
                "file"
            ]
        }
    }
}
