{
    "version": "0.2.0",
    "inputs": [
        {
            "id": "test-app-selector",
            "type": "pickString",
            "description": "Select Test Entry",
            "default": "@_LAUNCH_DEFAULT_TEST@",
            "options": [
                "@_LAUNCH_TESTS@"
            ]
        }
    ],
    "configurations": [
        {
            "name": "cppvsdbg-test-app",
            "type": "cppvsdbg",
            "request": "launch",
            "console": "internalConsole",
            "cwd": "${workspaceRoot}",
            "program": "@_BINARY_DIR@/test/bin/test-app",
            "args": [
                "--project-binary-dir=@_BINARY_DIR@",
                "--gtest_filter=${input:test-app-selector}"
            ],
            "environment": [
                {
                    "name": "PATH",
                    "value": "@_BINARY_DIR@/test/bin"
                }
            ]
        },
        {
            "name": "cppdbg-test-app",
            "type": "cppdbg",
            "request": "launch",
            "externalConsole": false,
            "avoidWindowsConsoleRedirection": true,
            "internalConsoleOptions": "openOnSessionStart",
            "MIMode": "gdb",
            "cwd": "${workspaceRoot}",
            "program": "@_BINARY_DIR@/test/bin/test-app",
            "args": [
                "--project-binary-dir=@_BINARY_DIR@",
                "--gtest_filter=${input:test-app-selector}"
            ],
            "environment": [
                {
                    "name": "PATH",
                    "value": "@_BINARY_DIR@/test/bin"
                }
            ]
        }
    ]
}